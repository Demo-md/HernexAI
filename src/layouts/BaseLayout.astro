---
import { ClientRouter } from "astro:transitions";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";
import Chatbot from "../components/chatbot/Chatbot.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedAt?: string;
  updatedAt?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "HerNexAI | Human-led marketing systems",
  description = "HerNexAI brings strategy, creative direction, and practical marketing execution together.",
  image,
  type = "website",
  publishedAt,
  updatedAt,
  noindex = false,
  jsonLd,
} = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const publicOrigin = siteUrl || Astro.url.origin;
const canonical = new URL(Astro.url.pathname, publicOrigin).toString();
const socialImage = image ? new URL(image, publicOrigin).toString() : undefined;
const jsonLdString = jsonLd ? JSON.stringify(jsonLd).replace(/</g, "\\u003c") : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#071B55" />
    <link rel="icon" href="/hernex-logo-official.svg" type="image/svg+xml" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    {type === "article" && publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {type === "article" && updatedAt && <meta property="article:modified_time" content={updatedAt} />}
    <meta name="twitter:card" content={socialImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    <link rel="canonical" href={canonical} />
    {jsonLdString && <script type="application/ld+json" set:html={jsonLdString}></script>}
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <button class="back-to-top" type="button" data-back-to-top aria-label="Back to top"><span aria-hidden="true">↑</span></button>
    <Chatbot />
    <script>
      import { mountSite } from "../scripts/site";

      let cleanup = () => {};
      let mounted = false;
      const initialise = () => {
        if (mounted) return;
        mounted = true;
        cleanup = mountSite();
      };
      const teardown = () => {
        cleanup();
        cleanup = () => {};
        mounted = false;
      };

      document.addEventListener("astro:before-swap", teardown);
      document.addEventListener("astro:page-load", initialise);
      if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", initialise, { once: true });
      else initialise();
    </script>
  </body>
</html>
