---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import HerNexChatbot from "../components/HerNexChatbot.astro";
const { title = "HerNexAI — Women-led Digital Marketing Agency", description = "Founded by Priyanka Jha, HerNexAI blends human creativity with smart technology to help entrepreneurs, coaches, small businesses, and women-driven ventures build authentic, scalable brands." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f4" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <ClientRouter fallback="animate" />
  </head>
  <body>
    <a href="#main" class="fixed left-4 top-3 z-[100] -translate-y-20 rounded-full bg-ink px-4 py-2 text-sm font-bold text-white focus:translate-y-0">Skip to content</a>
    <Navbar />
    <main id="main"><slot /></main>
    <Footer />
    <HerNexChatbot />
    <script>import "../scripts/motion";</script>
  </body>
</html>
