---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WhatsAppIcon from "../../components/WhatsAppIcon.astro";
import { contact, proofPoints, services } from "../../data/site";

const techService = services.find((service) => service.slug === "tech-services");
const marketingServices = services.filter((service) => service.slug !== "tech-services");
const nudgeMessage = "Looks like you’re comparing HerNexAI’s marketing and technology services. If you want the fastest path from scattered needs to a clear growth plan, talk to our dedicated team and we’ll help map the right structure for your business.";
const nudgePrompt = "I want to consult with HerNexAI about the right marketing and technology service structure for my business.";
---
<BaseLayout title="Marketing & Technology Services — HerNexAI" description="Explore HerNexAI branding, content, advertising, websites, SEO, automation, funnels, consulting, and technology services.">
  <section class="mesh pb-20 pt-32 md:pb-32 md:pt-48">
    <div class="container text-center">
      <p class="eyebrow">Marketing · Creative · Technology</p>
      <h1 class="hero-heading mx-auto mt-6 max-w-6xl font-black">Connected expertise for brands ready to build and grow.</h1>
      <p class="body-copy mx-auto mt-8 max-w-3xl text-muted">Start with the most urgent bottleneck. HerNexAI can connect strategy, content, acquisition, customer journeys, software, automation, and ongoing optimisation around one practical roadmap.</p>
      <div class="mt-9 flex flex-wrap justify-center gap-3"><a href={contact.whatsapp} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-full bg-[#25d366] px-6 py-4 text-sm font-black text-ink shadow-[0_14px_38px_rgba(37,211,102,.22)]"><WhatsAppIcon />Start WhatsApp Chat</a><a href="#marketing-services" class="rounded-full border border-ink/15 bg-paper/75 px-6 py-4 text-sm font-bold">Explore Services ↓</a></div>
    </div>
  </section>

  <section class="border-y border-line bg-paper py-8">
    <div class="container grid gap-6 text-center sm:grid-cols-2 sm:text-left lg:grid-cols-4">{proofPoints.map((point) => <article><strong class="text-4xl font-black tracking-[-.04em] text-blue">{point.value}</strong><p class="mt-2 text-sm leading-relaxed text-muted">{point.label}</p></article>)}</div>
  </section>

  <section id="marketing-services" class="container py-20 md:py-28">
    <div class="mx-auto max-w-5xl text-center"><p class="eyebrow">01 / Growth Services</p><h2 class="section-heading mt-5 font-black">Marketing capabilities that work together.</h2><p class="body-copy mx-auto mt-6 max-w-3xl text-muted">Every engagement starts with the business constraint—not a pre-packed list of deliverables. Select any service to see the challenge, approach, and available scope.</p></div>
    <div class="mt-14 grid gap-4 md:grid-cols-2">
      {marketingServices.map((service, index) => <a href={`/services/${service.slug}`} class="mobile-lazy-card group hairline rounded-[1.75rem] bg-white p-6 transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-blue/30 hover:shadow-[0_28px_80px_-48px_rgba(52,92,255,.45)] sm:p-8"><div class="flex items-start justify-between gap-3"><span class="eyebrow">{String(index + 1).padStart(2, "0")} / {service.kicker}</span><span class="grid size-11 shrink-0 place-items-center rounded-full bg-ink font-bold text-white transition-colors group-hover:bg-blue">↗</span></div><h3 class="card-heading mt-8 font-black sm:mt-10">{service.title}</h3><p class="body-copy mt-5 text-muted">{service.summary}</p><div class="mt-7 flex flex-wrap gap-2">{service.tags.map((tag) => <span class="rounded-full border border-line px-3 py-1.5 text-xs font-semibold text-muted">{tag}</span>)}</div></a>)}
    </div>
  </section>

  {techService && <section class="bg-ink py-20 text-white md:py-28">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-[.85fr_1.15fr] lg:items-end"><div><p class="eyebrow text-lime">02 / Growth Technology Services</p><h2 class="section-heading mt-5 font-black">Technology that supports the whole growth system.</h2></div><div><p class="body-copy max-w-2xl text-white/60">{techService.summary}</p><a href={`/services/${techService.slug}`} class="mt-7 inline-flex rounded-full bg-lime px-5 py-3 text-sm font-black text-ink">Explore Technology Services →</a></div></div>
      <div class="mt-14 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">{techService.includes.map((item, index) => <a href={`/services/${techService.slug}`} class="mobile-lazy-card group flex min-h-28 items-end justify-between rounded-2xl border border-white/10 bg-white/[.045] p-5 transition-colors hover:border-blue/50 hover:bg-white/[.075]"><div><span class="font-mono text-[10px] tracking-[.16em] text-white/30">{String(index + 1).padStart(2, "0")}</span><h3 class="mt-3 font-bold leading-snug">{item}</h3></div><span class="text-lime transition-transform group-hover:translate-x-1">→</span></a>)}</div>
    </div>
  </section>}

  <section class="container py-20 md:py-28">
    <div class="rounded-[2.25rem] border border-line bg-paper p-8 md:p-12"><p class="eyebrow">How HerNexAI Works</p><div class="mt-9 grid gap-8 md:grid-cols-3"><article><strong class="text-3xl font-black text-blue">01</strong><h3 class="mt-4 text-xl font-black">Craft with care</h3><p class="mt-3 leading-relaxed text-muted">Strategy and execution are shaped around the brand instead of relying on one-size-fits-all output.</p></article><article><strong class="text-3xl font-black text-blue">02</strong><h3 class="mt-4 text-xl font-black">Track the signal weekly</h3><p class="mt-3 leading-relaxed text-muted">Metrics are reviewed regularly so the next action comes from evidence rather than monthly guesswork.</p></article><article><strong class="text-3xl font-black text-blue">03</strong><h3 class="mt-4 text-xl font-black">Improve continuously</h3><p class="mt-3 leading-relaxed text-muted">Content, search visibility, community, conversion paths, and technology improve through consistent iteration.</p></article></div><p class="mt-8 text-xs leading-relaxed text-muted">Public proof points reflect HerNexAI’s published company content. Client-specific percentages should only be added after case-study approval.</p></div>
  </section>
  <script define:vars={{ nudgeMessage, nudgePrompt }}>
    document.addEventListener("astro:page-load", () => {
      if (location.pathname.replace(/\/$/, "") !== "/services") return;
      let shown = false;
      const onScroll = () => {
        if (shown) return;
        const maxScroll = document.documentElement.scrollHeight - innerHeight;
        if (maxScroll <= 0 || scrollY / maxScroll < .3) return;
        shown = true;
        window.removeEventListener("scroll", onScroll);
        setTimeout(() => {
          window.dispatchEvent(new CustomEvent("hernex:chat-nudge", { detail: {
            message: nudgeMessage,
            prompt: nudgePrompt
          }}));
        }, 120);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    });
  </script>
</BaseLayout>
