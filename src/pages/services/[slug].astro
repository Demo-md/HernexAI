---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WhatsAppIcon from "../../components/WhatsAppIcon.astro";
import { contact, proofPoints, services } from "../../data/site";
const service = services.find((item) => item.slug === Astro.params.slug);
if (!service) return Astro.redirect("/services");
const isTechService = service.slug === "tech-services";
const nudgeMessage = isTechService
  ? "Your technology stack quietly decides how fast your business can grow. If you’re unsure what to build first, consult HerNexAI’s dedicated team. We’ll map the right website, app, automation, CRM, cloud, and support structure for your goals."
  : `Your ${service.title.toLowerCase()} decisions shape how quickly people trust, remember, and choose your business. If you’re unsure what to prioritize first, consult HerNexAI’s dedicated team. We’ll map a focused structure for your goals, audience, and next growth stage.`;
const nudgePrompt = isTechService
  ? "I want to consult with HerNexAI about the right technology structure for my business."
  : `I want to consult with HerNexAI about ${service.title} for my business.`;
---
<BaseLayout title={`${service.title} — HerNexAI`} description={service.summary}>
  <section class:list={["mesh pt-32 md:pt-48", isTechService ? "pb-12 md:pb-16" : "pb-20 md:pb-32"]}><div class="container"><a href="/services" class="eyebrow hover:text-blue">← All Services</a><h1 class="hero-heading service-detail-heading mt-8 max-w-none font-black">{service.title}</h1><p class="body-copy mt-8 max-w-3xl text-muted">{service.summary}</p><div class="mt-8 flex flex-wrap gap-2">{service.tags.map((tag) => <span class="rounded-full border border-blue/15 bg-white/65 px-4 py-2 text-xs font-bold text-blue">{tag}</span>)}</div></div></section>
  <section class:list={["container", isTechService ? "py-12 md:py-20" : "py-16 md:py-32"]}><div class="grid gap-6 md:gap-12 lg:grid-cols-2"><article class="rounded-[1.5rem] bg-ink p-6 text-white sm:rounded-[2rem] sm:p-8 md:p-12"><p class="eyebrow text-white/45">The Challenge</p><h2 class="card-heading mt-8 font-black">What gets in the way</h2><p class="body-copy mt-6 text-white/60">{service.problem}</p></article><article class="hairline rounded-[1.5rem] bg-white p-6 sm:rounded-[2rem] sm:p-8 md:p-12"><p class="eyebrow">The HerNexAI Approach</p><h2 class="card-heading mt-8 font-black">How we solve it</h2><p class="body-copy mt-6 text-muted">{service.solution}</p></article></div>
    <div class:list={["mt-16 grid gap-10 md:mt-20 md:gap-12", isTechService ? "" : "lg:grid-cols-[.7fr_1.3fr]"]}><div class:list={isTechService ? "mx-auto max-w-5xl text-center" : ""}><p class="eyebrow">Engagement Scope</p><h2 class:list={["section-heading mt-5 font-black", isTechService ? "mx-auto max-w-4xl text-center" : ""]}>{isTechService ? "Premium technology systems built to remove growth friction." : "What can be included"}</h2><p class:list={["body-copy mt-6 text-muted", isTechService ? "mx-auto max-w-3xl text-center" : ""]}>{isTechService ? "Choose the capabilities that protect your time, improve customer experience, and make your business easier to scale. We clarify the roadmap first, then build the website, app, automation, cloud, data, and support layers that create measurable operational advantage." : "The final scope is tailored to the business goal, existing systems, available assets, and delivery priorities."}</p></div><div class="grid gap-3 sm:grid-cols-2">{service.includes.map((item, index) => <div class="mobile-lazy-card rounded-2xl border border-line bg-white p-6"><span class="eyebrow">{String(index + 1).padStart(2, "0")}</span><h3 class="mt-8 text-xl font-bold leading-snug tracking-[-.015em]">{item}</h3></div>)}</div></div>
  </section>
  <section class="border-y border-line bg-paper py-12"><div class="container grid gap-6 sm:grid-cols-2 lg:grid-cols-4">{proofPoints.map((point) => <article><strong class="text-4xl font-black tracking-[-.04em] text-blue">{point.value}</strong><p class="mt-2 text-sm leading-relaxed text-muted">{point.label}</p></article>)}</div></section>
  <section class="container py-20 md:py-36"><div class="rounded-[1.75rem] bg-blue p-6 text-center text-white sm:rounded-[2.5rem] sm:p-8 md:p-14 md:text-left"><p class="eyebrow text-white/60">Start a focused sprint</p><div class="mt-6 flex flex-col gap-8 md:flex-row md:items-end md:justify-between"><h2 class="section-heading max-w-4xl font-black">Let’s turn {service.title.toLowerCase()} into an advantage.</h2><a href={contact.whatsapp} target="_blank" rel="noreferrer" class="inline-flex w-full shrink-0 items-center justify-center gap-2 rounded-full bg-[#25d366] px-6 py-4 text-sm font-black text-ink sm:w-auto"><WhatsAppIcon />Start WhatsApp Chat</a></div></div></section>
  <script define:vars={{ nudgeMessage, nudgePrompt, serviceSlug: service.slug }}>
    document.addEventListener("astro:page-load", () => {
      if (!location.pathname.includes(`/services/${serviceSlug}`)) return;
      let shown = false;
      const onScroll = () => {
        if (shown) return;
        const maxScroll = document.documentElement.scrollHeight - innerHeight;
        if (maxScroll <= 0 || scrollY / maxScroll < .3) return;
        shown = true;
        window.removeEventListener("scroll", onScroll);
        setTimeout(() => {
          window.dispatchEvent(new CustomEvent("hernex:chat-nudge", { detail: {
            message: nudgeMessage,
            prompt: nudgePrompt
          }}));
        }, 120);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    });
  </script>
</BaseLayout>
