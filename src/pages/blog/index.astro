---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPosts } from "../../lib/blog";
const posts = (await getPosts()).filter((post) => post.status === "published");
const date = new Intl.DateTimeFormat("en-IN", { day: "numeric", month: "short", year: "numeric" });
---
<BaseLayout title="Ideas & Insights — HerNexAI" description="Practical ideas about branding, content, campaigns, websites, SEO, automation, funnels, and analytics.">
  <section class="mesh pb-24 pt-40 md:pb-32 md:pt-48"><div class="container"><p class="eyebrow">Ideas & Insights</p><h1 class="hero-heading mt-6 max-w-5xl font-black">Useful thinking for ambitious brands.</h1></div></section>
  <section class="container py-20 md:py-28">
    {posts.length ? <div class="grid gap-4 md:grid-cols-2">{posts.map((post, index) => <a href={`/blog/${post.slug}`} class={`hairline group overflow-hidden rounded-[1.75rem] bg-white transition-transform duration-300 hover:-translate-y-1 ${index === 0 ? "md:col-span-2 md:grid md:grid-cols-2" : ""}`}>{post.coverImage && <img src={post.coverImage} alt="" class="h-56 w-full object-cover md:h-full" loading="lazy" />}<div class="p-8"><span class="eyebrow">{date.format(new Date(post.date))}</span><h2 class="card-heading mt-10 font-black">{post.title}</h2><p class="body-copy mt-6 text-muted">{post.excerpt}</p><span class="mt-8 inline-block font-bold group-hover:text-blue">Read Article →</span></div></a>)}</div> : <p class="rounded-2xl border border-line bg-white p-8">New insights are being prepared.</p>}
  </section>
</BaseLayout>
