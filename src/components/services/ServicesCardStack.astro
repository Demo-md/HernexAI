---
import { services } from "../../data/site";
const techService = services.find((service) => service.slug === "tech-services");
const homepageServices = techService ? [services[0], techService, ...services.slice(1).filter((service) => service.slug !== "tech-services")] : services;
---
<section id="services" class="services-scroll-section services-stack-section relative bg-smoke">
  <div class="services-pin relative h-[100svh] min-h-[600px] overflow-hidden">
    <div class="services-stack-aura pointer-events-none absolute left-1/2 top-1/2 size-[42rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue/12 blur-[120px]"></div>
    <header class="services-copy services-intro absolute inset-x-4 top-[clamp(5rem,10vh,7rem)] z-20 mx-auto flex max-w-5xl flex-col items-center text-center">
      <p class="eyebrow">01 / Capabilities</p>
      <h2 class="mt-4 max-w-4xl text-center text-[clamp(2.25rem,4vw,4.5rem)] font-black leading-none tracking-[-.03em]">The right expertise, connected around growth.</h2>
      <p class="body-copy mt-4 max-w-3xl text-center text-muted">Start with the bottleneck. Add capabilities as your marketing system becomes ready for the next stage.</p>
    </header>

    <div class="services-stage absolute left-1/2 top-[70%] z-10 h-[clamp(310px,42vh,430px)] w-[min(860px,calc(100vw-48px))] -translate-x-1/2 -translate-y-1/2 [perspective:1600px] [transform-style:preserve-3d]">
      {homepageServices.map((service, index) => (
        <a href={`/services/${service.slug}`} class="service-stack-card absolute inset-0 flex h-full w-full origin-center flex-col justify-between overflow-hidden rounded-[2rem] border border-white/70 bg-white/80 p-7 shadow-[0_34px_100px_-55px_rgba(17,21,42,.45)] backdrop-blur-md md:p-9" data-stack-card={index} aria-hidden="false" tabindex="0">
          <div class="absolute -right-20 -top-24 size-72 rounded-full bg-gradient-to-br from-blue/20 via-lavender/20 to-peach/25 blur-3xl"></div>
          <div class="relative flex items-start justify-between"><span class="eyebrow tabular-nums">{String(index + 1).padStart(2, "0")}</span><span class="grid size-11 place-items-center rounded-full bg-ink text-white">↗</span></div>
          <div class="relative max-w-3xl"><h3 class="text-[clamp(1.75rem,3.2vw,3.25rem)] font-black leading-[1.03] tracking-[-.025em]">{service.title}</h3><p class="mt-4 max-w-2xl text-base leading-relaxed text-muted md:text-lg">{service.summary}</p></div>
          <div class="relative flex flex-wrap gap-2">{service.tags.map((tag) => <span class="rounded-full border border-line bg-paper/75 px-3 py-1.5 text-xs font-semibold text-muted">{tag}</span>)}</div>
        </a>
      ))}
    </div>

    <div class="services-progress absolute bottom-[clamp(1.25rem,3vh,2rem)] left-1/2 z-20 flex -translate-x-1/2 items-center gap-4"><span class="service-counter font-mono text-xs tabular-nums text-muted">01 / {String(homepageServices.length).padStart(2, "0")}</span><div class="flex gap-2">{homepageServices.map((_, index) => <span class:list={["service-progress-dot h-1.5 rounded-full bg-ink/15 transition-[width,background-color] duration-300", index === 0 ? "is-active w-8" : "w-1.5"]} data-stack-dot={index}></span>)}</div></div>
  </div>
</section>
