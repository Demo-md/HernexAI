---
import { parseArticle, type ArticleBlock } from "../../lib/article-content";

interface Props { content: string; }
const { content } = Astro.props;
const blocks = parseArticle(content);
const inline = (text: string) => text.split(/(\[[^\]]+\]\([^\)]+\))/g).filter(Boolean).map((part) => {
  const match = part.match(/^\[([^\]]+)\]\(([^\)]+)\)$/);
  return match ? { text: match[1], href: match[2] } : { text: part };
});
---

<div class="article-content">
  {blocks.map((block: ArticleBlock) => {
    if (block.type === "heading") return block.depth === 2 ? <h2 id={block.id}>{inline(block.text).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</h2> : <h3 id={block.id}>{inline(block.text).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</h3>;
    if (block.type === "paragraph") return <p>{inline(block.text).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</p>;
    if (block.type === "quote") return <blockquote><p>{block.text}</p></blockquote>;
    if (block.type === "list") return <ul>{block.items.map((item) => <li>{inline(item).map((part) => part.href ? <a href={part.href}>{part.text}</a> : part.text)}</li>)}</ul>;
    if (block.type === "code") return <pre><code>{block.text}</code></pre>;
    if (block.type === "divider") return <hr />;
    if (block.type === "callout") return <aside class="article-callout"><strong>{block.label}</strong><p>{block.text}</p></aside>;
    if (block.type === "image") return <figure><img src={block.src} alt={block.alt} loading="lazy" /></figure>;
    if (block.type === "table") return <div class="article-table-wrap"><table><thead><tr>{block.headers.map((header) => <th scope="col">{header}</th>)}</tr></thead><tbody>{block.rows.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody></table></div>;
    return null;
  })}
</div>
