---
interface Props {
  variant?: "hero" | "capabilities" | "footer";
}

const { variant = "hero" } = Astro.props;
const hasServiceCards = variant === "footer";

const channels = [
  { id: "instagram", label: "Instagram", glyph: "IG", angle: 0 },
  { id: "facebook", label: "Facebook", glyph: "f", angle: 45 },
  { id: "linkedin", label: "LinkedIn", glyph: "in", angle: 90 },
  { id: "reddit", label: "Reddit", glyph: "r", angle: 135 },
  { id: "youtube", label: "YouTube", glyph: "▶", angle: 180 },
  { id: "x", label: "X", glyph: "X", angle: 225 },
  { id: "whatsapp", label: "WhatsApp", glyph: "◔", angle: 270 },
  { id: "google", label: "Google Search", glyph: "G", angle: 315 },
] as const;

// These are verified HerNexAI capabilities, not claims of third-party partnerships.
const systems = [
  { id: "ai-agents", label: "AI agents", glyph: "AI", angle: 18 },
  { id: "automation", label: "Business automation", glyph: "AU", angle: 90 },
  { id: "crm", label: "CRM workflows", glyph: "CRM", angle: 162 },
  { id: "software", label: "Software development", glyph: "DEV", angle: 234 },
  { id: "web", label: "Web development", glyph: "WEB", angle: 306 },
] as const;

const serviceCards = [
  { id: "brand", serviceSlug: "branding-and-identity", eyebrow: "Brand and content", title: "Brand system", detail: "Make every expression recognisable and useful." },
  { id: "social", serviceSlug: "social-media-and-content", eyebrow: "Social campaign", title: "Social media system", detail: "Build a rhythm for content, community, and demand." },
  { id: "website", serviceSlug: "website-and-e-commerce", eyebrow: "Website experience", title: "Website experience", detail: "Give the next visitor a clear reason to stay and act." },
  { id: "crm", serviceSlug: "marketing-automation-and-ai", eyebrow: "CRM workflow", title: "CRM workflow", detail: "Keep customer context and follow up connected." },
  { id: "agent", serviceSlug: "tech-services", eyebrow: "AI agent", title: "AI agent", detail: "Support repeat questions with clear human handoffs." },
  { id: "automation", serviceSlug: "marketing-automation-and-ai", eyebrow: "Automation workflow", title: "Marketing automation", detail: "Reduce manual steps without losing visibility." },
  { id: "analytics", serviceSlug: "analytics-consulting-and-training", eyebrow: "Analytics", title: "Analytics and optimisation", detail: "Turn activity into clearer next decisions." },
] as const;
---

<figure class:list={["channel-orbit", `channel-orbit--${variant}`]} data-channel-orbit data-orbit-variant={variant} aria-labelledby={`channel-orbit-title-${variant}`}>
  <figcaption id={`channel-orbit-title-${variant}`} class="sr-only">Connected marketing channels and HerNexAI technology capabilities orbiting a growth system.</figcaption>
  <div class="channel-orbit__field">
    <svg class="channel-orbit__paths" viewBox="0 0 400 400" aria-hidden="true" focusable="false">
      <circle cx="200" cy="200" r="160"></circle>
      <circle cx="200" cy="200" r="108"></circle>
      <path d="M65 200H335"></path>
      <path d="M200 65V335"></path>
    </svg>

    <div class="channel-orbit__ring channel-orbit__ring--outer" data-orbit-ring="outer">
      {channels.map((channel) => (
        <button type="button" class="channel-orbit__token channel-orbit__token--channel" data-orbit-token={channel.id} style={`--orbit-angle: ${channel.angle}deg`} aria-label={`Show ${channel.label} context`}>
          <span class="channel-orbit__upright" data-orbit-upright="outer">
            <span class="channel-orbit__icon" data-orbit-icon>
              <svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
                {channel.id === "instagram" && <><rect x="5" y="5" width="22" height="22" rx="7"></rect><circle cx="16" cy="16" r="5"></circle><circle cx="22" cy="10" r="1.2" class="channel-orbit__fill"></circle></>}
                {channel.id === "youtube" && <><rect x="4" y="7" width="24" height="18" rx="5"></rect><path d="m14 12 7 4-7 4z" class="channel-orbit__fill"></path></>}
                {channel.id === "whatsapp" && <><circle cx="16" cy="16" r="11"></circle><path d="M12 10c2 5 5 8 10 10l-2.3 2.1c-5.2-1.6-8.2-4.6-9.8-9.8z"></path></>}
                {!(["instagram", "youtube", "whatsapp"] as string[]).includes(channel.id) && <text x="16" y="20" text-anchor="middle">{channel.glyph}</text>}
              </svg>
            </span>
          </span>
        </button>
      ))}
    </div>

    <div class="channel-orbit__ring channel-orbit__ring--inner" data-orbit-ring="inner">
      {systems.map((system) => (
        <button type="button" class="channel-orbit__token channel-orbit__token--system" data-orbit-token={system.id} style={`--orbit-angle: ${system.angle}deg`} aria-label={`Show ${system.label} context`}>
          <span class="channel-orbit__upright" data-orbit-upright="inner">
            <span class="channel-orbit__icon" data-orbit-icon><svg viewBox="0 0 32 32" aria-hidden="true" focusable="false"><text x="16" y="19" text-anchor="middle">{system.glyph}</text></svg></span>
          </span>
        </button>
      ))}
    </div>

    <span class="channel-orbit__signal" data-orbit-signal aria-hidden="true"></span>
    {hasServiceCards ? (
      <div class="channel-orbit__centre channel-orbit__centre--cards" aria-label="Featured HerNexAI capabilities">
        {serviceCards.map((card) => (
          <button class="channel-orbit__card" type="button" data-orbit-card={card.id} data-service-slug={card.serviceSlug} aria-label={`Ask HerNex Bot about ${card.title}`}>
            <span>{card.eyebrow}</span><strong>{card.title}</strong><small>{card.detail}</small><i aria-hidden="true">Ask HN Bot ↗</i>
          </button>
        ))}
      </div>
    ) : (
      <div class="channel-orbit__centre">
        <p data-orbit-context>Content and community</p>
        <strong>HN Growth<span>System</span></strong>
        <span>Connected channels</span>
      </div>
    )}
  </div>
</figure>
