---
import { contact } from "../data/site";
const quickActions = [["Branding", "What branding services does HerNexAI provide?"], ["Social media", "How can HerNexAI improve my social media?"], ["Website", "How can HerNexAI help with my website?"], ["Leads", "How can HerNexAI help me generate better leads?"], ["Automation", "What marketing automation can HerNexAI build?"], ["Support", "I need support with a HerNexAI service."]];
---
<div class="fixed bottom-[max(18px,env(safe-area-inset-bottom))] right-4 z-[60] md:bottom-8 md:right-8">
  <button id="chat-open" aria-label="Open HerNexAI Growth Assistant" class="chat-launcher group relative grid size-20 place-items-center rounded-full bg-transparent p-0 [perspective:700px]">
    <span class="chat-orbit pointer-events-none absolute inset-1 rounded-full border border-dashed border-blue/45"></span><span class="absolute right-1 top-2 size-2.5 rounded-full bg-lime shadow-[0_0_14px_rgba(223,255,114,.9)]"></span>
    <span class="chat-pulse chat-face relative grid size-16 place-items-center overflow-hidden rounded-full border border-white/30 bg-gradient-to-br from-blue via-[#167de5] to-[#19c99a] shadow-[0_14px_42px_rgba(52,92,255,.42)]"><span class="chat-word relative z-10 text-[9px] font-black uppercase tracking-[.08em] text-white">HerNex<span class="text-lime">AI</span></span><span class="chat-face-shine pointer-events-none absolute inset-0 bg-gradient-to-br from-white/30 via-transparent to-transparent"></span></span>
  </button>
</div>

<dialog id="chat-dialog" data-whatsapp={contact.whatsapp} data-lenis-prevent class="m-0 h-[min(680px,calc(100vh-16px))] w-[min(430px,calc(100vw-12px))] max-w-none self-end justify-self-end overflow-hidden overscroll-contain rounded-t-[1.75rem] border border-black/10 bg-paper p-0 shadow-2xl backdrop:bg-ink/35 md:mb-6 md:mr-6 md:rounded-[1.75rem]">
  <div class="flex h-full min-h-0 flex-col">
    <header class="relative shrink-0 overflow-hidden bg-ink p-5 text-white"><div class="absolute right-0 top-0 size-32 rounded-full bg-blue/40 blur-3xl"></div><div class="relative flex items-start justify-between"><div><p class="text-lg font-black tracking-[-.03em]">HerNexAI Growth Assistant</p><p class="mt-1 text-sm text-white/55">Enquiries, leads & basic support.</p></div><button id="chat-close" aria-label="Close growth assistant" class="grid size-10 place-items-center rounded-full bg-white/10 text-xl hover:bg-white/20">×</button></div></header>
    <div id="chat-messages" data-lenis-prevent class="min-h-0 flex-1 touch-pan-y space-y-3 overflow-y-auto overscroll-contain bg-smoke p-4" aria-live="polite">
      <div class="max-w-[88%] rounded-2xl rounded-tl-sm bg-paper p-4 text-sm leading-6 shadow-sm">Hi! Ask a marketing or technology service question, request pricing, or get support.</div>
      <div id="quick-actions" class="flex flex-wrap gap-2">{quickActions.map(([label, prompt]) => <button type="button" data-prompt={prompt} class="rounded-full border border-blue/15 bg-blue/5 px-3 py-2 text-xs font-bold text-blue hover:bg-blue hover:text-white">{label}</button>)}</div>
    </div>
    <footer class="shrink-0 border-t border-line bg-paper p-3">
      <form id="chat-form" class="flex gap-2"><label class="sr-only" for="chat-input">Ask HerNexAI a question</label><input id="chat-input" name="message" maxlength="500" autocomplete="off" placeholder="Ask about a service…" class="min-w-0 flex-1 rounded-full border border-line bg-smoke px-4 py-3 text-sm" required /><button class="rounded-full bg-ink px-4 text-sm font-bold text-white hover:bg-blue">Send</button></form>
      <p class="mt-2 px-2 text-[10px] leading-4 text-muted">By sharing contact details, you allow HerNexAI to follow up on your enquiry.</p>
    </footer>
  </div>
</dialog>

<script>
  type HistoryMessage = { role: "user" | "assistant"; content: string };
  type ChatState = { leadSaved: boolean; supportTicketCreated: boolean };
  document.addEventListener("astro:page-load", () => {
    const dialog = document.querySelector<HTMLDialogElement>("#chat-dialog"); const messages = document.querySelector<HTMLElement>("#chat-messages"); const input = document.querySelector<HTMLInputElement>("#chat-input"); const form = document.querySelector<HTMLFormElement>("#chat-form");
    if (!dialog || !messages || !input || !form || dialog.dataset.initialized === "true") return; dialog.dataset.initialized = "true";
    if (localStorage.getItem("hernex_chat_version") !== "2") { ["hernex_chat_session", "hernex_chat_history", "hernex_chat_state"].forEach((key) => localStorage.removeItem(key)); localStorage.setItem("hernex_chat_version", "2"); }
    const whatsappUrl = dialog.dataset.whatsapp || ""; const sessionId = localStorage.getItem("hernex_chat_session") || crypto.randomUUID(); localStorage.setItem("hernex_chat_session", sessionId);
    let history: HistoryMessage[] = JSON.parse(localStorage.getItem("hernex_chat_history") || "[]"); let state: ChatState = JSON.parse(localStorage.getItem("hernex_chat_state") || '{"leadSaved":false,"supportTicketCreated":false}'); let busy = false;
    const save = () => { history = history.slice(-32); localStorage.setItem("hernex_chat_history", JSON.stringify(history)); localStorage.setItem("hernex_chat_state", JSON.stringify(state)); };
    const scrollBottom = () => { if (messages) messages.scrollTop = messages.scrollHeight; };
    const bubble = (text: string, mine = false) => { const node = document.createElement("div"); node.className = `${mine ? "ml-auto bg-ink text-white rounded-tr-sm" : "bg-paper rounded-tl-sm"} max-w-[88%] rounded-2xl p-4 text-sm leading-6 shadow-sm break-words`; node.textContent = text; messages?.append(node); scrollBottom(); return node; };
    const trackWhatsApp = () => fetch("/api/chat", { method: "POST", headers: { "Content-Type": "application/json" }, keepalive: true, body: JSON.stringify({ sessionId, message: "Start WhatsApp Chat", history: history.slice(-24), state, event: "whatsapp_click" }) }).catch(() => {});
    const whatsappLink = (label = "Start WhatsApp Chat →") => { const link = document.createElement("a"); link.href = whatsappUrl; link.target = "_blank"; link.rel = "noreferrer"; link.className = "inline-flex rounded-full bg-[#25d366] px-4 py-2 text-xs font-bold text-ink"; link.textContent = label; link.addEventListener("click", trackWhatsApp); messages?.append(link); };
    const addContact = (contact: { email: string; phone: string; whatsapp: string }) => { const card = document.createElement("section"); card.className = "max-w-[94%] rounded-2xl border border-blue/20 bg-gradient-to-br from-blue/10 via-paper to-lavender/15 p-4 shadow-sm"; const title = document.createElement("p"); title.className = "text-xs font-black uppercase tracking-[.14em] text-blue"; title.textContent = "Contact HerNexAI"; const links = document.createElement("div"); links.className = "mt-3 grid gap-2"; const phone = document.createElement("a"); phone.href = `tel:${contact.phone.replaceAll(" ", "")}`; phone.className = "rounded-xl border border-line bg-paper/80 px-3 py-2 text-sm font-bold text-ink"; phone.textContent = `Call · ${contact.phone}`; const email = document.createElement("a"); email.href = `mailto:${contact.email}`; email.className = "break-words rounded-xl border border-line bg-paper/80 px-3 py-2 text-sm font-bold text-ink"; email.textContent = `Email · ${contact.email}`; const wa = document.createElement("a"); wa.href = contact.whatsapp; wa.target = "_blank"; wa.rel = "noreferrer"; wa.className = "rounded-xl bg-[#25d366] px-3 py-2 text-center text-sm font-bold text-ink"; wa.textContent = "Start WhatsApp Chat →"; wa.addEventListener("click", trackWhatsApp); links.append(phone, email, wa); card.append(title, links); messages?.append(card); scrollBottom(); };
    const typing = () => { const node = bubble("HerNexAI is typing…"); node.classList.add("animate-pulse", "text-muted"); return node; };
    const clearSuggestions = () => messages?.querySelector("[data-suggestions]")?.remove();
    const renderSuggestions = (actions: string[] = [], categories: string[] = []) => { clearSuggestions(); const choices = categories.length ? categories : actions; if (!choices.length) return; const wrap = document.createElement("div"); wrap.dataset.suggestions = "true"; wrap.className = "flex flex-wrap gap-2"; choices.forEach((label) => { if (label === "Start WhatsApp Chat") { const link = document.createElement("a"); link.href = whatsappUrl; link.target = "_blank"; link.rel = "noreferrer"; link.className = "rounded-full bg-[#25d366] px-3 py-2 text-xs font-bold text-ink"; link.textContent = label; link.addEventListener("click", trackWhatsApp); wrap.append(link); return; } if (label === "View Services") { const link = document.createElement("a"); link.href = "/services"; link.className = "rounded-full border border-blue/20 px-3 py-2 text-xs font-bold text-blue"; link.textContent = label; wrap.append(link); return; } const button = document.createElement("button"); button.type = "button"; button.className = "rounded-full border border-blue/20 px-3 py-2 text-xs font-bold text-blue"; button.textContent = label; button.addEventListener("click", () => ask(label)); wrap.append(button); }); messages?.append(wrap); scrollBottom(); };
    const ask = async (message: string, label = message) => { if (!input || busy || !message.trim()) return; busy = true; bubble(label, true); history.push({ role: "user", content: message }); save(); input.disabled = true; const indicator = typing();
      try { const response = await fetch("/api/chat", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ sessionId, message, history: history.slice(0, -1).slice(-24), state }) }); const data = await response.json(); indicator.remove(); const reply = data.reply || "Please try again or continue on WhatsApp."; bubble(reply); history.push({ role: "assistant", content: reply }); state = { leadSaved: state.leadSaved || Boolean(data.leadSaved), supportTicketCreated: state.supportTicketCreated || Boolean(data.supportTicketCreated) }; save(); if (data.contact) addContact(data.contact); renderSuggestions(data.suggestedActions, data.supportCategories); }
      catch { indicator.remove(); bubble("I’m temporarily unavailable. Please continue on WhatsApp."); whatsappLink(); }
      finally { busy = false; input.disabled = false; input.focus(); }
    };
    if (history.length && messages && !messages.dataset.restored) { messages.dataset.restored = "true"; history.slice(-6).forEach(({ role, content }) => bubble(content, role === "user")); }
    document.querySelector("#chat-open")?.addEventListener("click", () => dialog?.showModal()); document.querySelector("#chat-close")?.addEventListener("click", () => dialog?.close()); dialog?.addEventListener("click", (event) => { if (event.target === dialog) dialog.close(); });
    document.querySelectorAll<HTMLButtonElement>("#quick-actions button").forEach((button) => button.addEventListener("click", () => ask(button.dataset.prompt || button.textContent || "", button.textContent || "Question")));
    form?.addEventListener("submit", async (event) => { event.preventDefault(); const message = input?.value.trim(); if (!message) return; input.value = ""; await ask(message); });
  });
</script>
