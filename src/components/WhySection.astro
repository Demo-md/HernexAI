---
const points = [["Business-first strategy", "We begin with the real business constraint, not a package of fashionable deliverables."], ["Creative that converts", "Brand expression and commercial outcomes work together from the first idea."], ["Systems that save time", "Practical automation reduces repetitive follow-up, reporting, and coordination work."], ["Clarity by default", "You always know the priority, the signal, and the next practical move."]];
---
<section class="why-section relative overflow-hidden bg-gradient-to-b from-smoke via-ink to-ink pb-24 pt-40 text-white md:pb-36 md:pt-52">
  <div class="why-spotlight absolute left-[68%] top-[58%] size-[28rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue/20 blur-[120px]"></div>
  <div class="absolute -left-40 top-20 size-96 rounded-full bg-blue/15 blur-[120px]"></div><div class="absolute -right-32 bottom-0 size-96 rounded-full bg-peach/10 blur-[120px]"></div>
  <div class="container relative grid gap-12 lg:grid-cols-[.8fr_1.2fr]">
    <div class="flex flex-col items-center text-center"><p class="why-eyebrow eyebrow text-white/45">04 / Why HerNexAI</p><h2 class="mt-5 w-full max-w-[9.5ch] text-[clamp(3.15rem,5.4vw,5.7rem)] font-black leading-[.9] tracking-[-.03em]"><span class="why-heading-line block">One team.</span><span class="why-heading-line block">Fewer gaps.</span><span class="why-heading-line block">Better</span><span class="why-heading-line block">momentum.</span></h2><p class="why-copy body-copy mt-7 max-w-xl text-white/55">Founded by Priyanka Jha, HerNexAI is a women-led marketing agency that combines human creativity, purposeful strategy, and smart systems to help ambitious businesses grow with clarity.</p></div>
    <div class="why-grid relative grid overflow-hidden rounded-[1.75rem] border border-white/10 md:grid-cols-2">
      <span class="why-grid-line why-grid-line-x pointer-events-none absolute left-0 top-1/2 h-px w-full origin-left bg-white/10"></span><span class="why-grid-line why-grid-line-y pointer-events-none absolute bottom-0 left-1/2 hidden h-full w-px origin-top bg-white/10 md:block"></span>
      {points.map(([title, copy], index) => <article class="why-card group relative border-white/10 bg-ink/75 p-8 transition-[transform,border-color,box-shadow,background-color] duration-300 hover:-translate-y-1 hover:border-blue/35 hover:bg-white/[.055] md:p-10" data-why-card={index}><span class="eyebrow text-white/35">0{index + 1}</span><h3 class="mt-8 text-2xl font-bold leading-tight tracking-[-.02em] text-white/85 transition-colors duration-300 group-hover:text-white">{title}</h3><p class="body-copy mt-4 text-white/55 transition-opacity duration-300">{copy}</p><span class="absolute right-7 top-7 text-lg text-white/20 transition-[transform,color] duration-300 group-hover:translate-x-1 group-hover:-translate-y-1 group-hover:text-lavender">↗</span></article>)}
    </div>
  </div>
</section>
