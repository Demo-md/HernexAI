---
import { contact, services } from "../data/site";
import WhatsAppIcon from "./WhatsAppIcon.astro";
const techService = services.find((service) => service.slug === "tech-services");
const footerServices = techService ? [techService, ...services.filter((service) => service.slug !== "tech-services").slice(0, 5)] : services.slice(0, 6);
---
<footer class="relative overflow-hidden bg-ink px-4 py-16 text-white md:py-24">
  <div class="absolute -left-40 top-0 size-[34rem] rounded-full bg-blue/25 blur-[140px]"></div><div class="absolute -right-32 bottom-0 size-[30rem] rounded-full bg-peach/15 blur-[130px]"></div>
  <div class="container relative">
    <div class="grid items-start gap-10 rounded-[1.5rem] border border-white/10 bg-white/[.035] p-6 md:grid-cols-[1.15fr_.75fr_.75fr] md:rounded-[2rem] md:p-10 md:backdrop-blur">
      <div><p class="eyebrow text-white/45">Strategy · Creative · Technology</p><h2 class="mt-5 max-w-lg text-3xl font-black leading-[1.05] tracking-[-.025em] md:text-4xl">Let’s make your marketing easier to trust and easier to scale.</h2><div class="mt-7 flex flex-wrap gap-3"><a href={contact.whatsapp} target="_blank" rel="noreferrer" class="magnetic inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#25d366] px-5 py-3 text-sm font-black text-ink shadow-[0_12px_35px_rgba(37,211,102,.2)] hover:bg-lime sm:w-auto"><WhatsAppIcon />Start WhatsApp Chat</a><a href={`mailto:${contact.email}`} class="w-full rounded-full border border-white/30 bg-white/5 px-5 py-3 text-center text-sm font-bold text-white hover:bg-white hover:text-ink sm:w-auto">Email Team</a></div></div>
      <div><p class="mono text-white/45">Services</p><div class="mt-4 grid gap-2.5 text-xs leading-relaxed text-white/60 md:text-sm"><a href="/services" class="font-bold text-white hover:text-lime">All Services →</a>{footerServices.map((service) => <a href={`/services/${service.slug}`} class="hover:text-white">{service.title}</a>)}</div></div>
      <div><p class="mono text-white/45">Contact</p><div class="mt-4 grid gap-2.5 text-xs leading-relaxed text-white/60 md:text-sm"><a href={contact.whatsapp} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 font-bold text-[#25d366] hover:text-lime"><WhatsAppIcon />WhatsApp HerNexAI</a><a href={`mailto:${contact.email}`} class="break-words hover:text-white">{contact.email}</a><a href={`tel:${contact.phone.replaceAll(" ", "")}`} class="hover:text-white">{contact.phone}</a><span>India · Remote first delivery</span><a href="/blog" class="hover:text-white">Ideas & Insights</a><a href="/admin" class="font-bold text-white hover:text-lime">Admin Login</a></div></div>
    </div>
    <div class="mt-7 grid items-center gap-3 text-center text-[11px] leading-relaxed text-white/45 md:grid-cols-3 md:text-left">
      <span>© {new Date().getFullYear()} HerNexAI. All rights reserved.</span>
      <a href="https://www.insightsnode.com/" target="_blank" rel="noreferrer" class="insights-credit justify-self-center rounded-full border border-lavender/35 bg-lavender/10 px-4 py-2 font-bold text-[#ddd7ff] shadow-[0_0_28px_rgba(185,167,255,.22)] transition-[background-color,border-color,box-shadow] hover:border-lavender/60 hover:bg-lavender/15 hover:shadow-[0_0_36px_rgba(185,167,255,.35)]">Developed and powered by InsightsNode</a>
      <span class="md:text-right">Women led · Purposeful · Growth focused</span>
    </div>
  </div>
</footer>
