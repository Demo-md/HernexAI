---
import TestimonialProof from "../testimonials/TestimonialProof.astro";
---

<section class="capability-showcase section section--warm" data-strategy-section="capability" aria-labelledby="showcase-title">
  <div class="shell capability-showcase__grid">
    <TestimonialProof />
    <div class="capability-showcase__copy">
      <p class="section-index">04 / Capability</p>
      <h2 id="showcase-title"><span data-strategy-target="capability">Strategy</span> <span data-strategy-reveal>makes your value easier to choose and harder to ignore.</span></h2>
      <p data-strategy-reveal>Strong work does more than look polished. It makes the offer clearer, the next action easier and the system behind growth more dependable.</p>
      <a class="text-link text-link--dark" data-strategy-reveal href="/contact">Talk through a practical scope <span aria-hidden="true">↗</span></a>
    </div>
  </div>
</section>
