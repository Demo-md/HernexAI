---
const process = [
  ["Discover", "Listen for the real constraint, not just the visible symptom."],
  ["Position", "Define the message, audience, offer, and proof that make the next step clear."],
  ["Build", "Create the brand, content, pages, campaigns, or workflow needed to move."],
  ["Launch", "Put the right work in front of the right audience with a practical handoff."],
  ["Optimise", "Learn from the work, refine the system, and improve what matters."],
  ["Scale", "Make a useful rhythm repeatable without losing the human point of view."],
];
---

<section class="process-rail section section--light" aria-labelledby="process-title">
  <div class="shell process-rail__layout">
    <div class="process-rail__heading" data-reveal>
      <p class="section-index">05 / Working rhythm</p>
      <h2 id="process-title">A process with enough structure to move, and enough room to think.</h2>
      <a class="button button--outline" href="/contact">Book a Free Strategy Call <span aria-hidden="true">↗</span></a>
    </div>
    <ol class="process-rail__steps">
      {process.map(([title, copy], index) => (
        <li class="process-step" data-process-step>
          <span>0{index + 1}</span>
          <div><h3>{title}</h3><p>{copy}</p></div>
        </li>
      ))}
    </ol>
  </div>
</section>
