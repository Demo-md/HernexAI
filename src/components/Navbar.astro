---
import { contact } from "../data/site";
import WhatsAppIcon from "./WhatsAppIcon.astro";
const links = [["Process", "/#process"], ["Blog", "/blog"], ["FAQ", "/#faq"]];
---
<header id="site-header" class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-[background-color,border-color,box-shadow] duration-300">
  <span class="navbar-shine pointer-events-none absolute inset-y-0 w-36 bg-gradient-to-r from-transparent via-white/35 to-transparent"></span>
  <nav class="container relative flex h-16 items-center justify-between" aria-label="Main navigation">
    <a href="/" class="text-xl font-black tracking-[-0.025em]" translate="no">HerNex<span class="text-blue">AI</span></a>
    <div class="hidden items-center gap-7 text-sm font-semibold text-muted md:flex">
      <div class="group relative py-2">
        <button class="nav-link flex items-center gap-1 hover:text-ink" type="button" aria-haspopup="true">
          Services <span class="text-xs transition-transform group-hover:rotate-180">⌄</span>
        </button>
        <div class="pointer-events-none absolute left-1/2 top-full w-64 -translate-x-1/2 translate-y-2 rounded-3xl border border-line bg-paper/95 p-2 opacity-0 shadow-[0_24px_80px_-48px_rgba(17,21,42,.55)] backdrop-blur-xl transition duration-200 group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100">
          <a href="/services" class="group/item relative block overflow-hidden rounded-2xl px-4 py-3 transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_18px_50px_-34px_rgba(52,92,255,.75)]">
            <span class="absolute inset-y-0 left-0 w-1 origin-y scale-y-0 rounded-r-full bg-blue transition-transform duration-300 group-hover/item:scale-y-100"></span>
            <span class="block font-black text-ink transition-transform duration-300 group-hover/item:translate-x-2">Marketing</span>
            <span class="mt-1 block text-xs leading-relaxed text-muted transition-transform duration-300 group-hover/item:translate-x-2">Branding, content, ads, SEO, funnels.</span>
          </a>
          <a href="/services/tech-services" class="group/item relative block overflow-hidden rounded-2xl px-4 py-3 transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_18px_50px_-34px_rgba(52,92,255,.75)]">
            <span class="absolute inset-y-0 left-0 w-1 origin-y scale-y-0 rounded-r-full bg-blue transition-transform duration-300 group-hover/item:scale-y-100"></span>
            <span class="block font-black text-ink transition-transform duration-300 group-hover/item:translate-x-2">Technology</span>
            <span class="mt-1 block text-xs leading-relaxed text-muted transition-transform duration-300 group-hover/item:translate-x-2">Websites, apps, SaaS, automation, cloud.</span>
          </a>
        </div>
      </div>
      {links.map(([label, href]) => <a class="nav-link group relative py-2 hover:text-ink" data-section={href.includes("#") ? href.split("#")[1] : undefined} href={href}>{label}<span class="absolute inset-x-0 bottom-0 h-px origin-left scale-x-0 bg-blue transition-transform duration-300 group-hover:scale-x-100"></span></a>)}
    </div>
    <div class="flex items-center gap-2">
      <a href={contact.whatsapp} target="_blank" rel="noreferrer" aria-label="Start a WhatsApp chat with HerNexAI" class="magnetic hidden items-center gap-2 rounded-full bg-[#25d366] px-4 py-2.5 text-sm font-black text-ink shadow-[0_10px_28px_rgba(37,211,102,.24)] hover:bg-lime sm:inline-flex"><WhatsAppIcon />Start WhatsApp Chat</a>
      <button id="menu-open" aria-label="Open navigation menu" class="grid size-11 place-items-center rounded-full border border-line bg-paper text-xl md:hidden">☰</button>
    </div>
  </nav>
</header>

<dialog id="mobile-menu" class="m-0 h-full w-full max-w-none overflow-y-auto overscroll-contain bg-ink p-0 text-white backdrop:bg-ink/40">
  <div class="flex min-h-full flex-col px-5 pb-[max(28px,env(safe-area-inset-bottom))] pt-[max(20px,env(safe-area-inset-top))]">
    <div class="flex items-center justify-between"><a href="/" class="text-xl font-black">HerNex<span class="text-blue">AI</span></a><button id="menu-close" aria-label="Close navigation menu" class="grid size-11 place-items-center rounded-full bg-white/10 text-2xl">×</button></div>
    <div class="my-auto grid gap-2">
      <div class="border-b border-white/10 py-5">
        <div class="flex items-center justify-between text-4xl font-black leading-tight tracking-[-.03em]"><span>Services</span><span class="mono text-white/35">01</span></div>
        <div class="mt-5 grid gap-3 text-lg font-bold text-white/70">
          <a class="menu-link rounded-2xl bg-white/5 px-4 py-3 hover:bg-white/10 hover:text-white" href="/services">Marketing</a>
          <a class="menu-link rounded-2xl bg-white/5 px-4 py-3 hover:bg-white/10 hover:text-white" href="/services/tech-services">Technology</a>
        </div>
      </div>
      {links.map(([label, href], index) => <a class="menu-link flex items-center justify-between border-b border-white/10 py-5 text-4xl font-black leading-tight tracking-[-.03em]" href={href}><span>{label}</span><span class="mono text-white/35">0{index + 2}</span></a>)}
    </div>
    <a href={contact.whatsapp} target="_blank" rel="noreferrer" class="flex items-center justify-center gap-2 rounded-full bg-[#25d366] px-6 py-4 text-center font-black text-ink"><WhatsAppIcon />Start WhatsApp Chat</a>
  </div>
</dialog>

<script>
  let scrollController: AbortController | undefined;
  document.addEventListener("astro:page-load", () => {
    scrollController?.abort(); scrollController = new AbortController();
    const header = document.querySelector("#site-header");
    const dialog = document.querySelector<HTMLDialogElement>("#mobile-menu");
    document.querySelector("#menu-open")?.addEventListener("click", () => dialog?.showModal());
    document.querySelector("#menu-close")?.addEventListener("click", () => dialog?.close());
    dialog?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => dialog.close()));
    dialog?.addEventListener("click", (event) => { if (event.target === dialog) dialog.close(); });
    const updateHeader = () => { header?.classList.toggle("bg-smoke/90", window.scrollY > 20); header?.classList.toggle("border-line", window.scrollY > 20); header?.classList.toggle("shadow-sm", window.scrollY > 20); };
    updateHeader(); window.addEventListener("scroll", updateHeader, { passive: true, signal: scrollController.signal });
  });
</script>
