  <div class="hero-bg__grain"></div>
</div>

<script>
  const initHeroBackground = () => {
    const bg = document.querySelector<HTMLElement>(".hero-bg");
    if (!bg || matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    window.addEventListener("pointermove", (event) => {
      const x = (event.clientX / window.innerWidth - 0.5) * 18;
      const y = (event.clientY / window.innerHeight - 0.5) * 14;
      bg.style.setProperty("--mx", `${x}px`);
      bg.style.setProperty("--my", `${y}px`);
    }, { passive: true });
  };

  initHeroBackground();
  document.addEventListener("astro:page-load", initHeroBackground);
</script>

<style>
  .hero-bg {
    --mx: 0px;
    --my: 0px;
    background:
      radial-gradient(circle at 50% 32%, rgb(255 255 255 / .86), transparent 28%),
      radial-gradient(circle at 12% 18%, rgb(52 92 255 / .24), transparent 31%),
      radial-gradient(circle at 88% 20%, rgb(185 167 255 / .28), transparent 30%),
      radial-gradient(circle at 78% 78%, rgb(255 180 158 / .22), transparent 34%),
      radial-gradient(circle at 22% 82%, rgb(188 255 241 / .34), transparent 30%),
      linear-gradient(180deg, #fffefa 0%, #f8f7f2 100%);
    background-size: 120% 120%;
    animation: hero-gradient 18s ease-in-out infinite alternate;
  }

  .hero-bg__wash,
  .hero-bg__orb,
  .hero-bg__cinema,
  .hero-bg__svg,
  .hero-bg__grain {
    position: absolute;
    inset: 0;
  }

  .hero-bg__wash {
    background:
      linear-gradient(115deg, rgb(52 92 255 / .12), transparent 34%),
      linear-gradient(245deg, rgb(255 180 158 / .14), transparent 42%);
    filter: blur(20px);
    opacity: .78;
  }

  .hero-bg__orb {
    left: 50%;
    top: 38%;
    width: min(74vw, 860px);
    height: min(74vw, 860px);
    border: 1px solid rgb(255 255 255 / .5);
    border-radius: 999px;
    background: radial-gradient(circle, rgb(255 255 255 / .7), rgb(185 167 255 / .12) 46%, transparent 70%);
    box-shadow: 0 0 120px rgb(52 92 255 / .12), inset 0 0 90px rgb(255 255 255 / .4);
    transform: translate(calc(-50% + var(--mx) * .22), calc(-50% + var(--my) * .18));
    animation: hero-orb 8s ease-in-out infinite;
  }

  .hero-bg__cinema {
    inset: auto;
    bottom: -18%;
    width: min(46vw, 620px);
    height: 68%;
    opacity: .72;
    filter: blur(.2px);
    transform: translate3d(0, 0, 0);
    animation: cinema-drift 14s ease-in-out infinite alternate;
  }

  .hero-bg__cinema--left {
    left: -9%;
    background:
      radial-gradient(ellipse at 34% 18%, rgb(255 255 255 / .82) 0 22%, transparent 38%),
      radial-gradient(ellipse at 36% 54%, rgb(255 180 158 / .22) 0 34%, transparent 58%),
      radial-gradient(ellipse at 48% 88%, rgb(188 255 241 / .34) 0 38%, transparent 62%),
      linear-gradient(92deg, rgb(52 92 255 / .14), transparent 68%);
    border-top-right-radius: 80% 62%;
    border-bottom-right-radius: 54% 44%;
  }

  .hero-bg__cinema--right {
    right: -9%;
    background:
      radial-gradient(ellipse at 66% 18%, rgb(255 255 255 / .8) 0 22%, transparent 38%),
      radial-gradient(ellipse at 62% 55%, rgb(185 167 255 / .22) 0 36%, transparent 60%),
      radial-gradient(ellipse at 54% 88%, rgb(188 255 241 / .28) 0 38%, transparent 62%),
      linear-gradient(270deg, rgb(255 180 158 / .16), transparent 68%);
    border-top-left-radius: 80% 62%;
    border-bottom-left-radius: 54% 44%;
    animation-delay: -5s;
  }

  .hero-bg__cinema i {
    position: absolute;
    display: block;
    border-radius: 999px;
    background: rgb(255 255 255 / .54);
    box-shadow: 0 0 22px rgb(255 255 255 / .55);
    animation: cinema-spark 5.5s ease-in-out infinite;
  }

  .hero-bg__cinema i:nth-child(1) {
    left: 36%;
    top: 24%;
    width: 8px;
    height: 36px;
  }

  .hero-bg__cinema i:nth-child(2) {
    left: 68%;
    top: 58%;
    width: 18px;
    height: 52px;
    border: 3px solid rgb(185 167 255 / .28);
    background: transparent;
    box-shadow: none;
    animation-delay: 1.4s;
  }

  .hero-bg__cinema i:nth-child(3) {
    left: 58%;
    top: 77%;
    width: 16px;
    height: 48px;
    border: 3px solid rgb(52 92 255 / .16);
    background: transparent;
    box-shadow: none;
    animation-delay: 2.6s;
  }

  .hero-bg__cinema--right i:nth-child(1) { left: 58%; }
  .hero-bg__cinema--right i:nth-child(2) { left: 24%; }
  .hero-bg__cinema--right i:nth-child(3) { left: 34%; }

  .hero-bg__svg {
    width: 100%;
    height: 100%;
    opacity: .86;
    transform: translate(calc(var(--mx) * .55), calc(var(--my) * .4));
    transition: transform .45s ease-out;
  }

  .hero-bg__ribbons {
    filter: blur(.2px);
    animation: hero-ribbons 12s ease-in-out infinite alternate;
  }

  .hero-bg__network {
    stroke-dasharray: 9 14;
    animation: hero-network 16s linear infinite;
  }

  .hero-bg__sketch,
  .hero-bg__doodles,
  .hero-bg__marks {
    transform-box: fill-box;
    transform-origin: center;
  }

  .hero-bg__sketch {
    transform: translate(calc(var(--mx) * -.3), calc(var(--my) * -.22));
    transition: transform .45s ease-out;
  }

  .hero-bg__draw {
    stroke-dasharray: 360;
    stroke-dashoffset: 360;
    animation: sketch-draw 9s ease-in-out infinite;
  }

  .hero-bg__draw--slow {
    animation-duration: 13s;
  }

  .hero-bg__draw--delay {
    animation-delay: 2.4s;
  }

  .hero-bg__doodles {
    opacity: .88;
    transform: translate(calc(var(--mx) * .34), calc(var(--my) * .28));
    transition: transform .45s ease-out;
  }

  .hero-bg__doodle {
    transform-box: fill-box;
    transform-origin: center;
    stroke-dasharray: 420;
    stroke-dashoffset: 420;
    animation: doodle-draw 14s ease-in-out infinite;
  }

  .hero-bg__doodle--late {
    animation-delay: 3.2s;
  }

  .hero-bg__doodle--ring {
    display: none;
    animation: doodle-draw 15s ease-in-out infinite, doodle-float 9s ease-in-out infinite alternate;
  }

  .hero-bg__doodle--orbit {
    display: none;
    animation: doodle-breathe 8s ease-in-out infinite, doodle-rotate 26s linear infinite;
  }

  .hero-bg__arrow {
    animation-duration: 11s;
  }

  .hero-bg__growth {
    animation-duration: 10s;
  }

  .hero-bg__funnel {
    animation-duration: 16s;
  }

  .hero-bg__marks {
    stroke: #fffefa;
    stroke-opacity: .34;
    stroke-width: 2;
  }

  .hero-bg__marks path {
    animation: mark-pop 5.8s ease-in-out infinite;
  }

  .hero-bg__marks path:nth-child(2n) { animation-delay: 1.1s; }
  .hero-bg__marks path:nth-child(3n) { animation-delay: 2.2s; }

  .hero-bg__nodes circle {
    fill: #fffefa;
    opacity: .84;
    animation: hero-dot 3.4s ease-in-out infinite;
  }

  .hero-bg__nodes circle:nth-child(2n) { animation-delay: .8s; }
  .hero-bg__nodes circle:nth-child(3n) { animation-delay: 1.4s; }

  .hero-bg__grain {
    opacity: .18;
    mix-blend-mode: soft-light;
    background-image: radial-gradient(rgb(17 21 42 / .18) .7px, transparent .7px);
    background-size: 18px 18px;
    mask-image: radial-gradient(circle at 50% 40%, transparent 0 24%, #000 72%);
  }

  @keyframes hero-gradient {
    to { background-position: 70% 35%; }
  }

  @keyframes hero-orb {
    50% { opacity: .78; scale: 1.045; }
  }

  @keyframes hero-ribbons {
    to { transform: translate3d(34px, -18px, 0) scale(1.018); opacity: .9; }
  }

  @keyframes hero-network {
    to { stroke-dashoffset: -92; }
  }

  @keyframes hero-dot {
    50% { opacity: .35; transform: scale(.72); }
  }

  @keyframes cinema-drift {
    to { transform: translate3d(0, -18px, 0) scale(1.035); opacity: .86; }
  }

  @keyframes cinema-spark {
    50% { opacity: .36; transform: translateY(-18px) scale(.92); }
  }

  @keyframes sketch-draw {
    0%, 12% { opacity: 0; stroke-dashoffset: 360; }
    34%, 72% { opacity: 1; stroke-dashoffset: 0; }
    100% { opacity: 0; stroke-dashoffset: -360; }
  }

  @keyframes doodle-draw {
    0%, 15% { opacity: 0; stroke-dashoffset: 420; }
    38%, 76% { opacity: 1; stroke-dashoffset: 0; }
    100% { opacity: 0; stroke-dashoffset: -420; }
  }

  @keyframes doodle-float {
    to { transform: translate3d(12px, -18px, 0) rotate(5deg); }
  }

  @keyframes doodle-rotate {
    to { rotate: 360deg; }
  }

  @keyframes doodle-breathe {
    50% { opacity: .46; scale: 1.04; }
  }

  @keyframes mark-pop {
    0%, 62%, 100% { opacity: .08; transform: scale(.82); }
    72%, 88% { opacity: .52; transform: scale(1); }
  }

  @media (max-width: 767px) {
    .hero-bg__orb {
      top: 34%;
      width: 118vw;
      height: 118vw;
    }

    .hero-bg__cinema {
      width: 78vw;
      opacity: .44;
    }

    .hero-bg__cinema--left {
      left: -34%;
    }

    .hero-bg__cinema--right {
      right: -34%;
    }

    .hero-bg__svg {
      opacity: .62;
    }

    .hero-bg__marks,
    .hero-bg__doodle--orbit,
    .hero-bg__funnel {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg,
    .hero-bg__orb,
    .hero-bg__cinema,
    .hero-bg__cinema i,
    .hero-bg__ribbons,
    .hero-bg__network,
    .hero-bg__draw,
    .hero-bg__doodle,
    .hero-bg__marks path,
    .hero-bg__nodes circle {
      animation: none;
    }
  }
</style>
