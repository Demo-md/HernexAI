---
import FloatingMarketingObjects from "../FloatingMarketingObjects.astro";
---
<div id="growth-story" class="relative z-20 mx-auto mt-16 w-full max-w-[980px] md:mt-20">
  <div id="growth-stage" class="system-stage relative h-[460px] w-full overflow-hidden rounded-[2rem] border border-white/10 bg-ink shadow-[0_45px_140px_-65px_rgba(52,92,255,.72)] md:h-[560px]" aria-label="Scattered marketing activity connecting into the HerNex Growth Engine">
    <div class="system-glow absolute left-1/2 top-1/2 size-[22rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-br from-blue/40 via-lavender/25 to-peach/35 blur-[65px]"></div>
    <p class="pointer-events-none absolute inset-x-0 bottom-6 text-center text-[clamp(2.8rem,8vw,6.5rem)] font-black tracking-[-.03em] text-white/[.025]">GROWTH SYSTEM</p>

    <div class="stage-copy stage-chaos absolute inset-x-0 top-5 z-30 text-center md:top-7"><span class="eyebrow text-white/35">01 / Scattered marketing</span><p class="mt-1 text-sm font-semibold text-white/65">Strong activity without one shared direction.</p></div>
    <div class="stage-copy stage-system absolute inset-x-0 top-5 z-30 text-center md:top-7"><span class="eyebrow text-lavender">02 / Connected system</span><p class="mt-1 text-sm font-semibold text-white/65">Every channel now supports the same journey.</p></div>
    <div class="stage-copy stage-growth absolute inset-x-0 top-5 z-30 text-center md:top-7"><span class="eyebrow text-lime">03 / Compounding growth</span><p class="mt-1 text-sm font-semibold text-white/65">Clear signals create better decisions and momentum.</p></div>

    <div class="system-plane absolute inset-0" aria-hidden="true">
      <svg class="absolute inset-0 size-full" viewBox="0 0 900 540" preserveAspectRatio="none">
        <path class="system-line" d="M450 270 L450 105"/><path class="system-line" d="M450 270 L170 195"/><path class="system-line" d="M450 270 L730 190"/><path class="system-line" d="M450 270 L270 420"/><path class="system-line" d="M450 270 L640 415"/>
        <circle class="system-dot" cx="450" cy="105" r="5"/><circle class="system-dot" cx="170" cy="195" r="5"/><circle class="system-dot" cx="730" cy="190" r="5"/><circle class="system-dot" cx="270" cy="420" r="5"/><circle class="system-dot" cx="640" cy="415" r="5"/>
        <circle class="signal-pulse" cx="450" cy="270" r="4" fill="#dfff72"/>
      </svg>

      <div class="system-node left-1/2 top-[18%] -translate-x-1/2"><span>01</span><strong>Strategy</strong></div>
      <div class="system-node left-[19%] top-[36%] -translate-x-1/2"><span>02</span><strong>Content</strong></div>
      <div class="system-node left-[81%] top-[35%] -translate-x-1/2"><span>03</span><strong>Funnel</strong></div>
      <div class="system-node left-[30%] top-[78%] -translate-x-1/2"><span>04</span><strong>Automation</strong></div>
      <div class="system-node left-[71%] top-[77%] -translate-x-1/2"><span>05</span><strong>Analytics</strong></div>

      <div class="core-shell absolute left-1/2 top-1/2 size-40 -translate-x-1/2 -translate-y-1/2 md:size-52">
        <div class="core-ring core-ring-one absolute inset-0 rounded-full border border-lavender/65"></div><div class="core-ring core-ring-two absolute inset-4 rounded-full border border-dashed border-blue/70"></div>
        <div class="absolute inset-8 grid place-items-center rounded-full border border-white/20 bg-white/10 text-center shadow-[inset_0_0_38px_rgba(255,255,255,.08)] backdrop-blur-lg md:inset-10"><div><span class="block text-[9px] font-semibold uppercase tracking-[.16em] text-white/45">HerNex</span><strong class="mt-1 block text-base leading-tight tracking-[-.02em] text-white md:text-xl">Growth Engine</strong></div></div>
        <div class="growth-bars absolute inset-x-12 bottom-8 flex h-9 items-end justify-center gap-1 opacity-0 md:inset-x-16 md:bottom-11"><i class="growth-bar h-[30%]"></i><i class="growth-bar h-[48%]"></i><i class="growth-bar h-[68%]"></i><i class="growth-bar h-full"></i></div>
      </div>
      <FloatingMarketingObjects />
    </div>
  </div>
  <p class="mt-5 text-center text-xs font-medium text-muted">Scroll to connect the system ↓</p>
</div>
