</div>

<script>
  const initHeroSketch = () => {
    const layer = document.querySelector<HTMLElement>(".hero-sketch");
    if (!layer || layer.dataset.ready || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    layer.dataset.ready = "true";
    const heroWindow = window as Window & { __hernexHeroSketchFrame?: number };
    if (heroWindow.__hernexHeroSketchFrame) cancelAnimationFrame(heroWindow.__hernexHeroSketchFrame);

    const doodles = [...layer.querySelectorAll<SVGGElement>(".tiny-doodle")].map((node) => ({
      node,
      x: Number(node.dataset.x || 50),
      y: Number(node.dataset.y || 50),
      depth: Number(node.dataset.depth || .4),
    }));
    const waveA = layer.querySelector<SVGPathElement>("#cursor-wave-a");
    const waveB = layer.querySelector<SVGPathElement>("#cursor-wave-b");
    const waveC = layer.querySelector<SVGPathElement>("#cursor-wave-c");
    const hero = document.querySelector<HTMLElement>(".hero-section");
    const target = { x: 0, y: 0 };
    const smooth = { x: 0, y: 0 };
    const velocity = { x: 0, y: 0 };
    const smoothVelocity = { x: 0, y: 0 };

    hero?.addEventListener("pointermove", (event) => {
      const rect = hero.getBoundingClientRect();
      const nextX = (event.clientX - rect.left) / rect.width - 0.5;
      const nextY = (event.clientY - rect.top) / rect.height - 0.5;
      velocity.x = nextX - target.x;
      velocity.y = nextY - target.y;
      target.x = nextX;
      target.y = nextY;
    }, { passive: true });

    hero?.addEventListener("pointerleave", () => {
      target.x = 0;
      target.y = 0;
      velocity.x = 0;
      velocity.y = 0;
    }, { passive: true });

    const tick = () => {
      smooth.x += (target.x - smooth.x) * .14;
      smooth.y += (target.y - smooth.y) * .14;
      smoothVelocity.x += (velocity.x - smoothVelocity.x) * .18;
      smoothVelocity.y += (velocity.y - smoothVelocity.y) * .18;
      velocity.x *= .86;
      velocity.y *= .86;
      const x = smooth.x * 34 + smoothVelocity.x * 520;
      const y = smooth.y * 28 + smoothVelocity.y * 420;
      layer.style.setProperty("--sx", `${x}px`);
      layer.style.setProperty("--sy", `${y}px`);

      if (waveA && waveB && waveC) {
        const wx = smooth.x * 130 + smoothVelocity.x * 1100;
        const wy = smooth.y * 96 + smoothVelocity.y * 900;
        waveA.setAttribute("d", `M-60 610 C210 ${470 + wy} 390 ${770 - wy * .72} 620 ${650 + wy * .38} C850 ${530 - wy * .48} 1000 ${560 + wy * .34} 1500 ${400 + wx * .24}`);
        waveB.setAttribute("d", `M-60 780 C200 ${640 - wy * .42} 420 ${760 + wy * .38} 660 ${690 - wy * .24} C920 ${612 + wy * .4} 1110 ${650 - wy * .32} 1500 ${540 - wx * .2}`);
        waveC.setAttribute("d", `M-30 255 C210 ${170 + wy * .26} 390 ${260 - wy * .24} 548 ${210 + wy * .18} C770 ${140 - wy * .28} 1018 ${185 + wy * .24} 1470 ${115 + wx * .18}`);
      }

      doodles.forEach(({ node, x: doodleX, y: doodleY, depth }) => {
        const dx = smooth.x + .5 - doodleX / 100;
        const dy = smooth.y + .5 - doodleY / 100;
        const distance = Math.hypot(dx, dy);
        const influence = Math.max(0, 1 - distance / .58);
        const moveX = (smooth.x * 50 + smoothVelocity.x * 820 + dx * -38 * influence) * depth;
        const moveY = (smooth.y * 42 + smoothVelocity.y * 680 + dy * -32 * influence) * depth;
        const rotate = (smooth.x * 22 + smoothVelocity.x * 260 + influence * 12) * depth;
        node.setAttribute("transform", `translate(${(doodleX / 100) * 1440 + moveX} ${(doodleY / 100) * 980 + moveY}) rotate(${rotate})`);
      });

      heroWindow.__hernexHeroSketchFrame = requestAnimationFrame(tick);
    };

    tick();
  };

  initHeroSketch();
  document.addEventListener("astro:page-load", initHeroSketch);
</script>

<style>
  .hero-sketch {
    --sx: 0px;
    --sy: 0px;
    mix-blend-mode: multiply;
  }

  .hero-sketch__svg {
    width: 100%;
    height: 100%;
    opacity: .9;
    transform: translate(calc(var(--sx) * .55), calc(var(--sy) * .42));
    will-change: transform;
    mask-image: radial-gradient(ellipse at 50% 35%, transparent 0 25%, rgb(0 0 0 / .28) 43%, #000 72%);
  }

  .hero-sketch__waves {
    stroke: rgb(255 255 255 / .5);
    stroke-width: 9;
    opacity: .66;
    filter: drop-shadow(0 0 22px rgb(185 167 255 / .25));
  }

  .hero-sketch__waves path:nth-child(2) {
    stroke: rgb(185 167 255 / .34);
    stroke-width: 7;
  }

  .hero-sketch__waves path:nth-child(3) {
    stroke: rgb(223 255 247 / .38);
    stroke-width: 5;
  }

  .hero-sketch__pencil {
    stroke: #35405c;
    stroke-width: 2;
    stroke-opacity: .22;
  }

  .hero-sketch__doodles {
    stroke: #25304c;
    stroke-width: 2;
    stroke-opacity: .22;
  }

  .hero-sketch__nodes {
    stroke: #345cff;
    stroke-width: 1.8;
    stroke-opacity: .28;
    fill: rgb(52 92 255 / .28);
  }

  .hero-sketch__marks {
    stroke: #2b3552;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-opacity: .2;
  }

  .hero-sketch__tiny {
    stroke: #24304c;
    stroke-width: 1.55;
    stroke-opacity: .24;
  }

  .tiny-doodle {
    transform-box: fill-box;
    transform-origin: center;
    will-change: transform;
  }

  .tiny-doodle > * {
    vector-effect: non-scaling-stroke;
    animation: tiny-breathe 4.8s ease-in-out infinite;
  }

  .tiny-doodle.depth-2 {
    stroke: #345cff;
    stroke-opacity: .2;
  }

  .tiny-doodle.depth-3 {
    stroke: #b9a7ff;
    stroke-opacity: .24;
  }

  .tiny-doodle:nth-child(2n) > * { animation-delay: .9s; }
  .tiny-doodle:nth-child(3n) > * { animation-delay: 1.7s; }

  .sketch-line,
  .sketch-doodle,
  .node-line {
    stroke-dasharray: 520;
    stroke-dashoffset: 520;
    animation: pencil-draw 13s ease-in-out infinite;
  }

  .sketch-line.slow,
  .sketch-doodle.graph {
    animation-duration: 18s;
  }

  .delay,
  .late {
    animation-delay: 3s;
  }

  .whisper {
    stroke-opacity: .12;
  }

  .ring {
    display: none;
    transform-box: fill-box;
    transform-origin: center;
    animation: pencil-draw 16s ease-in-out infinite, sketch-float 9s ease-in-out infinite alternate;
  }

  .orbit {
    display: none;
    transform-box: fill-box;
    transform-origin: center;
    animation: sketch-orbit 28s linear infinite, sketch-breathe 7s ease-in-out infinite;
  }

  .arrow {
    animation-duration: 11s;
  }

  .hero-arrow {
    stroke-width: 2.4;
    stroke-opacity: .26;
    animation-duration: 15s;
  }

  .side-wave {
    stroke: #345cff;
    stroke-opacity: .14;
    stroke-width: 2.2;
    animation-duration: 19s;
  }

  .upper-loop {
    display: none;
    stroke: #b9a7ff;
    stroke-opacity: .2;
    stroke-width: 1.9;
    animation-duration: 17s;
  }

  .hero-sketch__nodes circle {
    animation: node-pulse 3.6s ease-in-out infinite;
  }

  .hero-sketch__nodes circle:nth-child(2n) {
    animation-delay: .9s;
  }

  .hero-sketch__marks path {
    animation: sketch-pop 6s ease-in-out infinite;
  }

  .hero-sketch__marks path:nth-child(2n) {
    animation-delay: 1.4s;
  }

  @keyframes pencil-draw {
    0%, 12% { opacity: 0; stroke-dashoffset: 520; }
    32%, 72% { opacity: 1; stroke-dashoffset: 0; }
    100% { opacity: 0; stroke-dashoffset: -520; }
  }

  @keyframes sketch-float {
    to { transform: translate3d(10px, -14px, 0) rotate(4deg); }
  }

  @keyframes sketch-orbit {
    to { rotate: 360deg; }
  }

  @keyframes sketch-breathe {
    50% { opacity: .42; scale: 1.04; }
  }

  @keyframes node-pulse {
    50% { opacity: .36; transform: scale(.74); }
  }

  @keyframes sketch-pop {
    0%, 62%, 100% { opacity: .1; transform: scale(.82); }
    76%, 88% { opacity: .65; transform: scale(1); }
  }

  @keyframes tiny-breathe {
    50% { opacity: .48; scale: .86; }
  }

  @media (max-width: 767px) {
    .hero-sketch__svg {
      opacity: .44;
      mask-image: radial-gradient(ellipse at 50% 30%, transparent 0 34%, #000 72%);
    }

    .hero-sketch__marks,
    .hero-sketch__tiny,
    .orbit,
    .funnel,
    .upper-loop,
    .side-wave {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sketch-line,
    .sketch-doodle,
    .node-line,
    .tiny-doodle > *,
    .hero-sketch__nodes circle,
    .hero-sketch__marks path {
      animation: none;
    }
  }
</style>
