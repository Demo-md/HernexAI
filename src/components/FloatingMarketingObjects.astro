---
const objects = [
  ["Content", "Calendar ready", "left-[5%] top-[18%] float-slow"],
  ["Ads", "Campaign live", "right-[5%] top-[20%] float-delay"],
  ["Website", "Conversion page", "left-[8%] top-[50%] float-delay"],
  ["SEO", "Visibility +18%", "right-[7%] top-[49%] float-slow"],
  ["WhatsApp", "New enquiry", "bottom-[9%] left-[5%] float-slow"],
  ["Analytics", "Signal found", "bottom-[8%] right-[4%] float-delay"],
  ["Automation", "Follow-up sent", "bottom-[28%] left-[20%] float-delay"],
  ["Leads", "+12 qualified", "bottom-[27%] right-[18%] float-slow"],
];
---
<div class="floating-marketing-objects absolute inset-0" aria-hidden="true">
  {objects.map(([label, detail, position], index) => (
    <div class:list={["marketing-object absolute z-20 rounded-xl border border-white/15 bg-white/[.08] px-3 py-2.5 text-left text-white shadow-[0_16px_40px_rgba(0,0,0,.24)] backdrop-blur-md", position]} data-object={index}>
      <span class="block text-[9px] font-semibold uppercase tracking-[.16em] text-white/40">{label}</span>
      <strong class="mt-1 block whitespace-nowrap text-[11px] font-semibold">{detail}</strong>
    </div>
  ))}
</div>
